---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Use BCH — txlab.cash">
  <section class="max-w-4xl mx-auto px-6 py-20">
    <div class="text-[10px] uppercase tracking-[0.2em] text-bch-500 font-mono font-semibold">// Pathway 01</div>
    <h1 class="mt-2 text-4xl md:text-5xl font-bold tracking-tight text-fg">Use BCH</h1>
    <p class="mt-6 text-lg text-fg-mid leading-relaxed">
      For people who want to transact — choose a wallet, send your first
      transaction, understand fees and privacy, find merchants who accept BCH.
    </p>
    <p class="mt-6 text-sm text-fg-mute font-mono">// Phase 1 in progress — content landing here soon.</p>
  </section>
</BaseLayout>
