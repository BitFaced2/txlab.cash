---
interface Props {
  href: string;
  title: string;
  body: string;
  icon: "use" | "build" | "run" | "grow";
  index: string;
}

const { href, title, body, icon, index } = Astro.props;
---

<a
  href={href}
  class="group relative block p-6 rounded-lg border border-line bg-surface hover:border-bch-500 hover:bg-elevated transition-all duration-200 glow-bch-hover">
  {/* Corner brackets */}
  <span
    class="absolute top-2 left-2 w-2.5 h-2.5 border-l border-t border-line-mid group-hover:border-bch-500 transition-colors"
    aria-hidden="true"></span>
  <span
    class="absolute top-2 right-2 w-2.5 h-2.5 border-r border-t border-line-mid group-hover:border-bch-500 transition-colors"
    aria-hidden="true"></span>
  <span
    class="absolute bottom-2 left-2 w-2.5 h-2.5 border-l border-b border-line-mid group-hover:border-bch-500 transition-colors"
    aria-hidden="true"></span>
  <span
    class="absolute bottom-2 right-2 w-2.5 h-2.5 border-r border-b border-line-mid group-hover:border-bch-500 transition-colors"
    aria-hidden="true"></span>

  <div class="flex items-start justify-between">
    <div class="w-10 h-10 rounded-md bg-canvas border border-line flex items-center justify-center text-bch-500 group-hover:border-bch-500 group-hover:text-bch-400 transition-colors">
      {icon === "use" && (
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
          <path d="M20 8H4v12h16V8Z" />
          <path d="M4 8V6a2 2 0 0 1 2-2h10l4 4" />
          <circle cx="16" cy="14" r="1.5" />
        </svg>
      )}
      {icon === "build" && (
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
          <path d="M8 4H6a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h2" />
          <path d="M16 4h2a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2h-2" />
          <path d="m10 9-2 3 2 3" />
          <path d="m14 9 2 3-2 3" />
        </svg>
      )}
      {icon === "run" && (
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
          <rect x="3" y="4" width="18" height="5" rx="1" />
          <rect x="3" y="15" width="18" height="5" rx="1" />
          <path d="M7 6.5h.01M7 17.5h.01" />
          <path d="M12 9v6" />
        </svg>
      )}
      {icon === "grow" && (
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 20V10" />
          <path d="M12 10c-3 0-5-2-5-5 3 0 5 2 5 5Z" />
          <path d="M12 10c3 0 5-2 5-5-3 0-5 2-5 5Z" />
          <path d="M6 20h12" />
        </svg>
      )}
    </div>
    <span class="font-mono text-[11px] text-neon-400 mt-1 tabular tracking-tight">{index}</span>
  </div>

  <h3 class="mt-5 font-semibold text-lg text-fg group-hover:text-bch-400 transition-colors">
    {title}
  </h3>
  <p class="mt-1.5 text-sm text-fg-mute leading-relaxed">{body}</p>

  <div class="mt-4 flex items-center gap-1.5 text-xs font-mono text-fg-dim group-hover:text-bch-500 transition-colors uppercase tracking-wider">
    <span>Enter</span>
    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transform group-hover:translate-x-1 transition-transform">
      <path d="M5 12h14" />
      <path d="m12 5 7 7-7 7" />
    </svg>
  </div>
</a>
